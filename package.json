{
  "name": "slash",
  "version": "1.0.0",
  "description": "Slash messaging app with accounts and profile pictures",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check index.js && node --check directs.js && node --check global-tracking.js",
    "check:db": "node --check scripts/export-json-to-postgres.js && node --check lib/db.js && node --check lib/postgres-store.js && node --check lib/api-utils.js && node --check lib/feed-ranking.js",
    "check:feed": "node --check scripts/feed-ranking-test.js && node scripts/feed-ranking-test.js",
    "check:smoke": "node --check scripts/smoke-test.js && node scripts/smoke-test.js",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1",
    "db:export": "node scripts/export-json-to-postgres.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  }
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0"
  },
  "author": "You",
  "license": "MIT",
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
